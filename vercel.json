{
  "functions": {
    "api/tdsystem-records.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/tdsystem-records",
      "destination": "/api/tdsystem-records.js"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
